# ============================================================
# call-me-maybe  –  Environment Variables Template
# ============================================================
# Copy this file to .env and fill in real values.
# Values defined here override any environment variables that
# are already set in the shell.
# ============================================================

# ----------------------------------------------------------
# Remote API keys
# ----------------------------------------------------------

# OpenRouter API key (used when provider = "remote" with OpenRouter)
OPENROUTER_API_KEY=

# OpenAI API key (used when provider = "remote" with api.openai.com)
OPENAI_API_KEY=

# Generic OpenAI-compatible API key (used when base_url is a custom endpoint)
# Falls back to OPENAI_API_KEY if not set.
API_KEY=

# ----------------------------------------------------------
# Fish Audio (TTS / voice synthesis)
# ----------------------------------------------------------

# Fish Audio API key  –  https://fish.audio
FISH_AUDIO_API_KEY=

# Fish Audio voice reference ID to use for synthesis
FISH_AUDIO_VOICE_ID=

# ----------------------------------------------------------
# Optional: tool / skill API keys
# ----------------------------------------------------------

# Brave Search (used by the brave-search MCP server example)
BRAVE_API_KEY=

# Alpha Vantage API key (stock market data MCP server – https://www.alphavantage.co)
ALPHAVANTAGE_API_KEY=

# ----------------------------------------------------------
# Optional: logging / debug
# ----------------------------------------------------------

# Set to "debug" for verbose output; "info" for normal output; "warning" (default) for quiet
LOG_LEVEL=warning
