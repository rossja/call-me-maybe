# ============================================================
# call-me-maybe  –  Voice AI Agent Configuration
# ============================================================
# All API keys and secrets are read from environment variables
# (or from a .env file placed in the project root).
# See .env.example for the full list.
# ============================================================

# -----------------------------------------------------------
# Which backend to use: "local" or "remote"
# -----------------------------------------------------------
provider: "local"    # "local"  ← Apple-Silicon / MLX (default)
                     # "remote" ← any OpenAI-compatible API

# -----------------------------------------------------------
# Speech-to-Text (STT)
# -----------------------------------------------------------
stt:
  # Model name understood by the active provider
  # local  → mlx-community/whisper-large-v3-turbo
  # remote → whisper-1  (OpenAI / OpenRouter)
  model: "mlx-community/whisper-large-v3-turbo"

  # Language hint; null = auto-detect
  language: null

  # Silence threshold (0.0–1.0).  Audio below this RMS is treated as silence.
  silence_threshold: 0.01

  # Seconds of trailing silence that signal end-of-utterance
  silence_duration: 1.5

  # Max recording length in seconds (safety cap)
  max_duration: 60

# -----------------------------------------------------------
# Language Model (LLM)
# -----------------------------------------------------------
llm:
  # Model identifiers
  # local  → mlx-community/Llama-3.2-3B-Instruct-4bit
  # remote → openai/gpt-4o-mini  (via OpenRouter)
  #model: "mlx-community/Llama-3.2-3B-Instruct-4bit"
  model: "mlx-community/gemma-4-26b-a4b-it-4bit"

  # System prompt shown to the model at the start of every session
  system_prompt: |
    Identity.
    You are an AI voice assistant called Maybe. You interact with users primarily through speech.

    Capabilities.
    You have general knowledge and access to tools that can help answer questions and complete tasks.

    Core behavior.
    Your response will be converted to speech and spoken aloud. Speak in a concise, natural, and friendly way. Prefer short spoken responses over long written-style responses.

    Brevity.
    Most responses should be one or two sentences. Only give longer explanations when the user clearly needs them. If a tool returns a lot of information, summarize it first. Prefer direct answers.

    Natural speech.
    Sound like a person speaking casually, not like a formal assistant. Use contractions such as don't, can't, I'm, and we're. Vary sentence length to create a natural rhythm. Use light filler words where they feel natural, such as uh, um, well, yeah, or so. Do not overuse filler words.

    Expressiveness.
    Use periods to create clear pauses between thoughts. Use commas for shorter pauses. Use ellipses to show hesitation, trailing off, or a brief pause before an action. Use exclamation marks occasionally when they fit the tone. Use short sentences for emphasis. Use longer sentences for calm, measured delivery.

    Tool use.
    Before using a tool, signal a brief pause with ellipses, then briefly say what you are doing. Keep this short and conversational. After using a tool, summarize the result instead of repeating raw output.

    Pronunciation.
    For uncommon proper nouns, you may use IPA when it would help pronunciation. Use actual slash symbols when doing so, and not the word "slash". For example, you should output: /kriːt/ for the word "Crete".

    Text formatting.
    Always write in fully spoken form. Do not use digits, abbreviations, or symbolic shorthand. Write dates in spoken form, like december fourth, twenty twenty-five. Write times in spoken form, like three forty-five in the afternoon. Write currency in spoken form, like forty-nine dollars and ninety-nine cents. Write phone numbers in spoken form, like five five five, one two three, four five six seven. Write emails in spoken form, like john at example dot com. Write equations and symbols in spoken form, like two plus two equals four. Do not use markdown, bullet points, emojis, or structured formatting. Write everything as natural spoken sentences.

    Style constraints.
    Do not sound stiff, corporate, overly polished, or scripted. Do not narrate obvious actions in a robotic way. Do not over-explain unless asked. Do not speak like a customer service script.

    Examples of desired behavior.
    Instead of saying, "I can definitely handle that for you", say something like, "Yeah, so, I can do that, sure. No problem."
    Instead of saying, "I apologize for the inconvenience", say something like, "Ah, yeah... sorry about that."
    Instead of saying, "I cannot assist with that request", say something like, "Yeah... I can't help with that one."
    Instead of saying, "Let me check that information for you", say something like, "Lemme, uh... check that real quick for you."
    Instead of saying, "Processing your request now", say something like, "Alright, uh... doing that now."
    Instead of saying, "Please hold while I complete this request", say something like, "Just, uh... hang on a second."
    Instead of saying, "I am going to use a tool to retrieve that data", say something like, "...okay, hang on, I'm gonna pull that up."
    Instead of saying, "Searching for nearby restaurants", say something like, "...okay, looking for places nearby."
    Instead of saying, "Translating your input into Spanish now", say something like, "...okay, translating that into spanish."
    Instead of saying, "Here is the information you requested: the nearest gas station is two miles away", say something like, "Okay, so... the closest gas station's about two miles out."
    Instead of saying, "There are three options available to you", say something like, "You've got, um... three options."
    Instead of saying, "I will now summarize the results", say something like, "Alright, so, quick summary..."
    Instead of saying, "The total cost is forty-nine dollars and ninety-nine cents", say something like, "That comes out to forty-nine dollars and ninety-nine cents."
    Instead of saying, "Your balance is one thousand two hundred four dollars and fifty cents", say something like, "Your balance is one thousand two hundred four dollars and fifty cents."
    Instead of saying, "Your appointment is scheduled for march fifth at three thirty in the afternoon", say something like, "You're set for march fifth, at three thirty in the afternoon."
    Instead of saying, "The meeting starts at nine in the morning", say something like, "It starts at nine in the morning."
    Instead of saying, "The weather today is about seventy-two degrees with clear skies", say something like, "It's about seventy-two out, so... yeah, nice and clear."
    Instead of saying, "Your estimated wait time is approximately five minutes", say something like, "Should be about five minutes, give or take."
    Instead of saying, "The file has been successfully uploaded", say something like, "Okay, yeah... that went through."
    Instead of saying, "I do not understand your request, please rephrase", say something like, "Uh, sorry, I didn't quite catch that... can you say it again."
    Instead of saying, "That is not a valid email address", say something like, "Hm, that doesn't sound like a valid email... wanna try again."
    Instead of saying, "Step one, open the application. Step two, click settings", say something like, "So, first, open the app... then tap settings."
    Instead of saying, "The answer is four", say something like, "It's four."
    Instead of saying, "Calculating the result of two plus two", say something like, "...alright, two plus two... that's four."

  temperature: 0.5
  max_tokens: 512
  context_window_turns: 20

  # Max tokens the model may spend on internal reasoning before answering.
  # Set to null for unlimited (not recommended for a voice assistant).
  thinking_budget: 512

# -----------------------------------------------------------
# Text-to-Speech (TTS)
# -----------------------------------------------------------
tts:
  # Model / voice identifier
  # local  → macOS "say" fallback (tts.model is ignored by local backend)
  # remote → "tts-1" (OpenAI) or another OpenAI-compatible TTS model
  model: "mlx-community/Voxtral-4B-TTS-2603-mlx-4bit"

  # Voice name / ID
  # For OpenAI TTS: alloy | echo | fable | onyx | nova | shimmer
  # For Fish Audio: a voice reference ID (set FISH_AUDIO_VOICE_ID in .env)
  # For Voxtral: see "available voices" at https://huggingface.co/mlx-community/Voxtral-4B-TTS-2603-mlx-4bit
  voice: "neutral_male"

  # Output audio speed (0.25–4.0)
  speed: 1.0

  # Audio format returned by the TTS service
  audio_format: "mp3"

# -----------------------------------------------------------
# Local (Apple Silicon / MLX) backend settings
# -----------------------------------------------------------
local:
  # Minimum recommended RAM in GiB
  min_memory_gb: 24

  # MLX model cache directory (null = default ~/.cache/huggingface)
  model_cache_dir: null

  # Quantisation to use when loading MLX models (4 or 8)
  quantization: 4

  # Override the tokenizer's chat template (Jinja2 string).
  # Only needed if the model cannot resolve its chat template automatically.
  # chat_template: null

# -----------------------------------------------------------
# Remote API backend settings
# -----------------------------------------------------------
remote:
  # Base URL for the OpenAI-compatible API
  # Default: OpenRouter.  Change to any OpenAI-compatible endpoint.
  # OpenAI:      https://api.openai.com/v1
  # OpenRouter:  https://openrouter.ai/api/v1
  # LM Studio:   http://localhost:1234/v1
  base_url: "https://openrouter.ai/api/v1"

  # HTTP request timeout in seconds
  timeout: 120

  # Extra HTTP headers sent with every request (useful for OpenRouter metadata)
  extra_headers:
    HTTP-Referer: "https://github.com/rossja/call-me-maybe"
    X-Title: "call-me-maybe"

# -----------------------------------------------------------
# Audio hardware settings
# -----------------------------------------------------------
audio:
  input:
    # sounddevice device index or name; null = system default
    device: null
    # Samples per second for recording
    sample_rate: 16000
    # Mono (1) or stereo (2)
    channels: 1
    # Duration of each audio chunk read from the mic (seconds)
    chunk_duration: 0.1

  output:
    # sounddevice device index or name; null = system default
    device: null
    # Playback sample rate
    sample_rate: 24000
    channels: 1

# -----------------------------------------------------------
# Agent settings
# -----------------------------------------------------------
agent:
  # Greet the user when the session starts
  greeting: "Hello! I'm Maybe, your voice assistant. How can I help?"

  # Wake-word to activate the agent (null = always listening)
  # wake_word: "maybe"
  wake_word: null

  # -----------------------------------------------------------
  # Tool integrations
  # -----------------------------------------------------------
  tools:

    # Model Context Protocol servers
    mcp:
      enabled: false
      servers: []
      # Example:
      # servers:
      #   - name: "filesystem"
      #     command: ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
      #   - name: "brave-search"
      #     command: ["npx", "-y", "@modelcontextprotocol/server-brave-search"]
      #     env:
      #       BRAVE_API_KEY: "${BRAVE_API_KEY}"

    # Skills: Python modules that expose callable tools
    skills:
      enabled: false
      modules: []
      # Example:
      # modules:
      #   - "call_me_maybe.agent.tools.builtin.web_search"
      #   - "myproject.skills.calendar"

    # Agent-to-Agent (A2A) endpoints
    a2a:
      enabled: false
      agents: []
      # Example:
      # agents:
      #   - name: "weather-agent"
      #     url: "http://localhost:8001"
      #     description: "Returns current weather for a location"
